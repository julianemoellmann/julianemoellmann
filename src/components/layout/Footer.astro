---
import { siteConfig } from "@/config/site";
---

<footer class="mt-20 border-t border-border">
  <div class="mx-auto max-w-5xl px-5 py-10 sm:px-8">
    <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
      <div>
        <span
          class="font-mono text-xs uppercase tracking-[0.22em] text-foreground"
          >{siteConfig.author}</span
        >
        <p class="mt-3 max-w-xl text-sm leading-6 text-muted-foreground">
          {siteConfig.description}
        </p>
      </div>
      <div
        class="flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-xs uppercase tracking-[0.14em]"
      >
        <a
          href={siteConfig.socialLinks.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition-colors hover:text-primary"
          >LinkedIn</a
        >
        <a
          href={siteConfig.socialLinks.googleScholar}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition-colors hover:text-primary"
          >Google Scholar</a
        >
        <a
          href={siteConfig.socialLinks.researchgate}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition-colors hover:text-primary"
          >ResearchGate</a
        >
      </div>
    </div>
    <div class="mt-8 font-mono text-xs text-muted-foreground">
      {new Date().getFullYear()} / built as one rendering of an academic surface
    </div>
  </div>
</footer>
