---
import { siteConfig } from "@/config/site";

const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-border bg-background">
  <div class="mx-auto max-w-5xl px-5 py-8 sm:px-8">
    <div
      class="grid gap-6 font-mono text-xs uppercase leading-relaxed tracking-[0.14em] text-muted-foreground md:grid-cols-[1fr_auto] md:items-start"
    >
      <div class="space-y-1">
        <p class="tracking-[0.22em] text-foreground">{siteConfig.author}</p>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
          <span>&copy; {year}</span>
          <span>/</span>
          <a
            href="/imprint"
            class="transition-colors hover:text-foreground"
          >
            Imprint
          </a>
          <span>/</span>
          <a
            href="/privacy-policy"
            class="transition-colors hover:text-foreground"
          >
            Privacy Policy
          </a>
        </div>
      </div>

      <nav
        class="flex flex-wrap gap-x-5 gap-y-1 md:max-w-md md:justify-end"
        aria-label="Footer links"
      >
        {
          [
            ["LinkedIn", siteConfig.socialLinks.linkedin],
            ["ORCID", siteConfig.socialLinks.orcid],
            ["Google Scholar", siteConfig.socialLinks.googleScholar],
            ["ResearchGate", siteConfig.socialLinks.researchgate],
          ].map(([label, href]) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors hover:text-foreground"
            >
              {label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</footer>
