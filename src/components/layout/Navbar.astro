---
import { siteConfig } from "@/config/site";
import { sitePath } from "@/utils/paths";

const visibleLinks = siteConfig.navLinks.filter((link) => link.text !== "Home");
---

<nav
  class="fixed top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur-sm"
>
  <div
    class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4 sm:px-8"
  >
    <a
      href={sitePath("/")}
      class="font-mono text-xs uppercase tracking-[0.22em] text-foreground transition-colors hover:text-primary"
    >
      Juliane Möllmann
    </a>

    <div class="hidden lg:block">
      <div class="flex items-baseline gap-4">
        {
          visibleLinks.map((link, index) => (
            <>
              {index > 0 && (
                <span
                  class="font-mono text-xs uppercase tracking-[0.14em] text-border"
                  aria-hidden="true"
                >
                  /
                </span>
              )}
              <a
                href={sitePath(link.href)}
                class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground transition-colors hover:text-foreground"
              >
                {link.text}
              </a>
            </>
          ))
        }
      </div>
    </div>

    <div class="flex items-center lg:hidden">
      <button
        id="mobile-menu-button"
        type="button"
        class="inline-flex items-center justify-center border border-border px-3 py-2 font-mono text-xs uppercase tracking-[0.14em] text-foreground transition-colors hover:border-foreground"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        Menu
      </button>
    </div>
  </div>

  <div class="hidden lg:hidden" id="mobile-menu">
    <div
      class="space-y-1 border-b border-border bg-background px-5 pb-5 pt-2 sm:px-8"
    >
      {
        visibleLinks.map((link) => (
          <a
            href={sitePath(link.href)}
            class="block py-2 font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground transition-colors hover:text-foreground"
          >
            {link.text}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script>
  document.addEventListener("astro:page-load", () => {
    const button = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");

    // Remove old event listener if it exists to prevent multiple triggers
    const newButton = button?.cloneNode(true);
    if (newButton && button && button.parentNode) {
      button.parentNode.replaceChild(newButton, button);
    }

    const finalButton = document.getElementById("mobile-menu-button");

    finalButton?.addEventListener("click", () => {
      const isExpanded = finalButton.getAttribute("aria-expanded") === "true";

      finalButton.setAttribute("aria-expanded", String(!isExpanded));
      menu?.classList.toggle("hidden");
    });
  });
</script>
