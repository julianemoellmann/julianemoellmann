---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getImage } from "astro:assets";
import Content2 from "@/components/widgets/Content2.astro";
import Values from "@/components/widgets/Values.astro";
import aboutImage from "@/assets/images/about-office.webp";

const metadata = {
  title: "About Juliane Möllmann",
  description:
    "Learn more about Juliane Möllmann, PhD, a Postdoc researcher specializing in innovation management and strategy.",
};

const values = [
  {
    title: "Knowledge Exchange",
    description:
      "Facilitating the sharing of knowledge between organizations and individuals to drive innovation.",
  },
  {
    title: "Corporate-Startup Collaborations",
    description:
      "Exploring partnerships between established companies and startups for mutual growth and innovation.",
  },
  {
    title: "Self-strategizing",
    description:
      "Developing strategies for personal and organizational self-improvement and adaptation.",
  },
  {
    title: "Artificial Intelligence",
    description:
      "Integrating AI technologies into business processes and research methodologies.",
  },
  {
    title: "Qualitative Methods",
    description:
      "Utilizing qualitative research approaches to understand complex organizational phenomena.",
  },
];

const optimizedImage = await getImage({
  src: aboutImage,
  format: "webp",
});
---

<BaseLayout {metadata}>
  <link slot="head" rel="preload" href={optimizedImage.src} as="image" />
  <Content2
    title="About Me"
    description={[
      "Hej! I am a Postdoc at the Department of Industrial Engineering and Management of Aalto University, School of Science. Before that, I was a senior solution engineer at the Deloitte Innovation Delivery Center in Berlin.",
      "Within my PhD project, my research focus was on knowledge processes, corporate-startup collaboration, and qualitative methods. I have interests in Knowledge Exchange, Corporate-Startup Collaborations, Self-strategizing, Artificial Intelligence, and Qualitative Methods.",
      "I teach on topics of organizations, innovation management, strategy, entrepreneurship, and technologies in studies focusing on business. I conducted my studies in Germany, Denmark, Portugal, UK and USA.",
      "For about ten years, I worked in the industry as innovation manager, scrum master and technical consultant. I also took different community roles in the AOM SAP community, representative associations, and local initiatives.",
    ]}
    tagline="Biography"
    image={aboutImage}
    imageAlt="Juliane Möllmann"
    actions={[
      {
        text: "View Research",
        href: "/research",
        variant: "primary",
        icon: "lucide:book-open",
      },
      {
        text: "Contact Me",
        href: "/contact",
        variant: "secondary",
        icon: "lucide:mail",
      },
    ]}
  />
  <Values
    items={values}
    columns={3}
    tagline="Interests"
    title="My Research Interests"
    subtitle="Areas that drive my academic and professional pursuits"
  />
</BaseLayout>
