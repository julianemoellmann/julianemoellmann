const activities = ["Lectures", "Supervision", "Examination"];
const topics = [
  "Artificial Intelligence",
  "Business Model Innovation",
  "Business Plan",
  "Entrepreneurship",
  "Innovation",
  "Knowledge",
  "Literature Review",
  "Organization Theory",
  "Qualitative Research",
  "SCRUM",
  "Strategy",
  "Technology",
];

const levels = ["Bachelor Level", "Master Level", "PhD Level"];

const sortedTeachingItems = [...teachingItems].sort((a, b) =>
  a.title.localeCompare(b.title),
);
---

<BaseLayout {metadata}>
  <section class="mx-auto max-w-5xl px-5 py-12 sm:px-8 md:py-16">
    <div>
      <div class="flex items-center gap-5">
        <img
          src={sitePath("/icons/teaching.svg")}
          alt=""
          aria-hidden="true"
          class="h-12 w-12 shrink-0 sm:h-14 sm:w-14"
        />
        <h1
          class="max-w-4xl text-5xl font-normal leading-none tracking-normal text-foreground sm:text-7xl"
        >
          Teaching
        </h1>
      </div>
      <p class="mt-8 max-w-3xl text-2xl leading-tight text-foreground">
        I teach and coordinate courses across Bachelor, Master, and PhD levels
        with a focus on management, innovation, strategy, and digital
        transformation.
      </p>
    </div>
  </section>

  <section class="border-y border-border">
    <div class="mx-auto max-w-5xl px-5 py-8 sm:px-8">
      <div class="grid gap-8 lg:grid-cols-[12rem_1fr]">
        <div>
          <p
            class="font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground"
          >
            Filters
          </p>
          <p
            id="teaching-count"
            class="mt-3 font-mono text-xs uppercase tracking-[0.14em] text-foreground"
          >
            {sortedTeachingItems.length} items
          </p>
        </div>

        <form id="teaching-filters" class="space-y-7">
          <fieldset>
            <legend
              class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground"
            >
              Activity
            </legend>
            <div class="mt-3 flex flex-wrap gap-3">
              {
                activities.map((activity) => (
                  <label class="inline-flex cursor-pointer items-center gap-2 border border-border px-3 py-2 font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground">
                    <input
                      class="h-3 w-3 accent-foreground"
                      type="checkbox"
                      name="activity"
                      value={activity}
                    />
                    {activity}
                  </label>
                ))
              }
            </div>
          </fieldset>

          <fieldset>
            <legend
              class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground"
            >
              Topic
            </legend>
            <div class="mt-3 flex flex-wrap gap-2">
              {
                topics.map((topic) => (
                  <button
                    class="topic-filter border border-border px-2 py-1 font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground aria-pressed:border-foreground aria-pressed:bg-foreground aria-pressed:text-background"
                    type="button"
                    data-topic={topic}
                    aria-pressed="false"
                  >
                    {topic}
                  </button>
                ))
              }
            </div>
          </fieldset>

          <fieldset>
            <legend
              class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground"
            >
              Level
            </legend>
            <div class="mt-3 flex flex-wrap gap-2">
              {
                levels.map((level) => (
                  <button
                    class="level-filter border border-border px-2 py-1 font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground aria-pressed:border-foreground aria-pressed:bg-foreground aria-pressed:text-background"
                    type="button"
                    data-level={level}
                    aria-pressed="false"
                  >
                    {level.replace(" Level", "")}
                  </button>
                ))
              }
            </div>
          </fieldset>

          <button
            id="clear-teaching-filters"
            class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground underline transition-colors hover:text-foreground"
            type="button"
          >
            Clear filters
          </button>
        </form>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <div
        class="grid gap-0 lg:max-h-[72rem] lg:overflow-y-auto lg:pr-2"
        id="teaching-list"
      >
        {
          sortedTeachingItems.map((item) => (
            <article
              class="teaching-item grid gap-8 border-b border-border py-10 last:border-b-0 lg:grid-cols-[12rem_1fr]"
              data-activities={item.activities.join("|")}
              data-topics={item.topics.join("|")}
              data-level={item.level}
            >
              <div>
                <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">
                  {item.activities.join(" / ")}
                </p>
              </div>

              <div>
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <h2 class="max-w-3xl text-3xl font-normal leading-tight text-foreground sm:text-4xl">
                    {item.title}
                  </h2>
                  <a
                    href={item.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="shrink-0 font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground underline transition-colors hover:text-foreground"
                  >
                    Course page
                  </a>
                </div>

                <div class="mt-6 grid gap-5 md:grid-cols-3">
                  <div>
                    <h3 class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground">
                      Level
                    </h3>
                    <p class="mt-2 text-sm leading-6 text-foreground">
                      {item.level}
                    </p>
                  </div>
                  <div>
                    <h3 class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground">
                      Semester
                    </h3>
                    <p class="mt-2 text-sm leading-6 text-foreground">
                      {item.semester}
                    </p>
                  </div>
                  <div>
                    <h3 class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground">
                      Students
                    </h3>
                    <p class="mt-2 text-sm leading-6 text-foreground">
                      {item.students || "n/a"}
                    </p>
                  </div>
                </div>

                <div class="mt-6 grid gap-5 md:grid-cols-[1fr_1.4fr]">
                  <div>
                    <h3 class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground">
                      Topic
                    </h3>
                    <p class="mt-2 text-sm leading-6 text-foreground">
                      {item.topics.join(" / ")}
                    </p>
                  </div>
                  <div>
                    <h3 class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground">
                      Course responsible
                    </h3>
                    <p class="mt-2 text-sm leading-6 text-foreground">
                      {item.responsible}
                    </p>
                  </div>
                </div>

                <div class="mt-7 border-t border-border pt-5">
                  <h3 class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground">
                    Contribution
                  </h3>
                  <ul class="mt-3 space-y-2 text-sm leading-6 text-muted-foreground">
                    {item.details.map((detail) => (
                      <li>{detail}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <script>
    const filterForm = document.getElementById("teaching-filters");
    const clearButton = document.getElementById("clear-teaching-filters");
    const countElement = document.getElementById("teaching-count");
    const items = Array.from(document.querySelectorAll(".teaching-item"));
    const topicButtons = Array.from(document.querySelectorAll(".topic-filter"));
    const levelButtons = Array.from(document.querySelectorAll(".level-filter"));

    const getPressedValues = (buttons) =>
      buttons
        .filter((button) => button.getAttribute("aria-pressed") === "true")
        .map((button) => button.dataset.topic || button.dataset.level);

    const getCheckedActivities = () =>
      Array.from(
        document.querySelectorAll('input[name="activity"]:checked'),
      ).map((input) => input.value);

    const itemMatches = (
      item,
      selectedActivities,
      selectedTopics,
      selectedLevels,
    ) => {
      const activities = item.dataset.activities.split("|");
      const topics = item.dataset.topics.split("|");
      const level = item.dataset.level;

      const activityMatch =
        selectedActivities.length === 0 ||
        selectedActivities.some((activity) => activities.includes(activity));
      const topicMatch =
        selectedTopics.length === 0 ||
        selectedTopics.some((topic) => topics.includes(topic));
      const levelMatch =
        selectedLevels.length === 0 ||
        selectedLevels.some((selectedLevel) => level.includes(selectedLevel));

      return activityMatch && topicMatch && levelMatch;
    };

    const updateFilters = () => {
      const selectedActivities = getCheckedActivities();
      const selectedTopics = getPressedValues(topicButtons);
      const selectedLevels = getPressedValues(levelButtons);
      let visibleCount = 0;

      items.forEach((item) => {
        const isVisible = itemMatches(
          item,
          selectedActivities,
          selectedTopics,
          selectedLevels,
        );
        item.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      });

      if (countElement) {
        countElement.textContent = `${visibleCount} item${visibleCount === 1 ? "" : "s"}`;
      }
    };

    [...topicButtons, ...levelButtons].forEach((button) => {
      button.addEventListener("click", () => {
        const isPressed = button.getAttribute("aria-pressed") === "true";
        button.setAttribute("aria-pressed", String(!isPressed));
        updateFilters();
      });
    });

    filterForm?.addEventListener("change", updateFilters);

    clearButton?.addEventListener("click", () => {
      filterForm
        ?.querySelectorAll('input[type="checkbox"]')
        .forEach((input) => {
          input.checked = false;
        });
      [...topicButtons, ...levelButtons].forEach((button) => {
        button.setAttribute("aria-pressed", "false");
      });
      updateFilters();
    });
  </script>
</BaseLayout>
