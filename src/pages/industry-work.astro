---

<BaseLayout {metadata}>
  <section class="mx-auto max-w-5xl px-5 py-12 sm:px-8 md:py-16">
    <div>
      <div class="flex items-center gap-5">
        <img
          src={sitePath("/icons/industry-work.svg")}
          alt=""
          aria-hidden="true"
          class="h-12 w-12 shrink-0 sm:h-14 sm:w-14"
        />
        <h1
          class="max-w-4xl text-5xl font-normal leading-none tracking-normal text-foreground sm:text-7xl"
        >
          Industry Work
        </h1>
      </div>
      <p class="mt-8 max-w-3xl text-2xl leading-tight text-foreground">
        Before returning fully to academia, I worked across innovation
        management, technical project management, Scrum, digital platforms, and
        payment innovation.
      </p>
    </div>
  </section>

  <section class="border-y border-border">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <div class="divide-y divide-border">
        {
          workExperience.map((item) => (
            <article class="grid gap-8 py-10 lg:grid-cols-[12rem_1fr]">
              <div>
                <p class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground">
                  {item.period}
                </p>
              </div>

              <div>
                <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <h2 class="text-3xl font-normal leading-tight text-foreground sm:text-4xl">
                      {item.role}
                    </h2>
                    <p class="mt-3 text-base leading-7 text-muted-foreground">
                      {item.company} / {item.location}
                    </p>
                  </div>
                  <img
                    src={sitePath(item.icon)}
                    alt=""
                    aria-hidden="true"
                    class="h-10 w-10 shrink-0 object-contain opacity-85 sm:mt-1"
                    loading="lazy"
                  />
                </div>

                <ul class="mt-6 grid gap-3 text-sm leading-6 text-foreground sm:grid-cols-2">
                  {item.details.map((detail) => (
                    <li class="border-t border-border pt-3">{detail}</li>
                  ))}
                </ul>

                {item.projectPages && (
                  <div class="mt-7 border-t border-border pt-5">
                    <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">
                      Work projects
                    </p>
                    <div class="mt-3 grid gap-3">
                      {item.projectPages.map((project) => (
                        <a
                          href={sitePath(`/industry-work/projects/${project.slug}`)}
                          class="text-sm leading-6 text-foreground underline decoration-border underline-offset-4 transition-colors hover:text-muted-foreground"
                        >
                          {project.title}
                        </a>
                      ))}
                    </div>
                  </div>
                )}

                {item.projects && (
                  <div class="mt-7 border-t border-border pt-5">
                    <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">
                      Projects included
                    </p>
                    <p class="mt-3 text-sm leading-6 text-foreground">
                      {item.projects.join(" / ")}
                    </p>
                  </div>
                )}

                {item.projectLink && (
                  <a
                    href={item.projectLink.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-6 inline-flex font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground underline transition-colors hover:text-foreground"
                  >
                    {item.projectLink.label}
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-b border-border">
    <div class="mx-auto max-w-5xl px-5 py-12 sm:px-8">
      <div class="grid gap-8 lg:grid-cols-[12rem_1fr]">
        <p
          class="pt-7 font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground"
        >
          Freelance
        </p>
        <div>
          <h2
            class="text-3xl font-normal leading-tight text-foreground sm:text-4xl"
          >
            {freelancerExperience.title}
          </h2>
          <div class="mt-5 grid gap-3">
            {
              freelancerExperience.projectPages.map((project) => (
                <a
                  href={sitePath(`/industry-work/projects/${project.slug}`)}
                  class="text-sm leading-6 text-foreground underline decoration-border underline-offset-4 transition-colors hover:text-muted-foreground"
                >
                  {project.title}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-5xl px-5 py-12 sm:px-8">
      <div class="grid gap-8 lg:grid-cols-[12rem_1fr]">
        <p
          class="pt-7 font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground"
        >
          Early Career
        </p>

        <div class="divide-y divide-border">
          {
            earlyCareer.map((item) => (
              <article class="grid gap-5 py-7 md:grid-cols-[9rem_1fr]">
                <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">
                  {item.period}
                </p>
                <div>
                  <h2 class="text-2xl font-normal leading-tight text-foreground">
                    {item.area}
                  </h2>
                  <p class="mt-2 text-sm leading-6 text-muted-foreground">
                    {item.company}
                  </p>
                  <p class="mt-4 text-sm leading-6 text-foreground">
                    {item.focus.join(" / ")}
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border">
    <div class="mx-auto max-w-5xl px-5 py-12 sm:px-8">
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground">
        Technical Experiences
      </p>
      <div
        class="mt-7 flex flex-wrap gap-x-3 gap-y-2 font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground"
      >
        {
          technicalExperiences.map((item) => (
            <span class="border border-border px-2 py-1">{item}</span>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-border">
    <div class="mx-auto max-w-5xl px-5 py-12 sm:px-8">
      <div class="grid gap-8 lg:grid-cols-[12rem_1fr]">
        <p
          class="pt-7 font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground"
        >
          Certificates
        </p>

        <div class="divide-y divide-border">
          {
            certificates.map((item) => (
              <article class="grid gap-5 py-7 md:grid-cols-[9rem_1fr]">
                <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">
                  {item.date}
                </p>
                <h2 class="text-2xl font-normal leading-tight text-foreground">
                  {item.title}
                </h2>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border">
    <div class="mx-auto max-w-5xl px-5 py-12 sm:px-8">
      <div class="grid gap-8 lg:grid-cols-[12rem_1fr]">
        <p
          class="pt-7 font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground"
        >
          Languages
        </p>

        <div class="divide-y divide-border">
          {
            languages.map((item) => (
              <article class="grid gap-5 py-7 md:grid-cols-[9rem_1fr]">
                <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">
                  {item.level}
                </p>
                <h2 class="text-2xl font-normal leading-tight text-foreground">
                  {item.language}
                </h2>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
