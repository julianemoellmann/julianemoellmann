---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import { sitePath } from "@/utils/paths";

const metadata = {
  title: `${siteConfig.name} — Innovation Management and Strategy`,
  description:
    "Personal academic website for Juliane Möllmann, PhD: research, teaching, education, community roles, and industry work.",
  ignoreTitleTemplate: true,
};

const navItems = [
  {
    href: "/research",
    icon: "/icons/research.svg",
    label: "Research",
    description:
      "I study the organizational implications of emerging digital technologies, particularly generative AI, software development, open-source ecosystems, and innovation collaboration.",
  },
  {
    href: "/teaching",
    icon: "/icons/teaching.svg",
    label: "Teaching",
    description:
      "I teach and coordinate courses across Bachelor, Master, and PhD levels with a focus on management, innovation, strategy, and digital transformation.",
  },
  {
    href: "/education",
    icon: "/icons/education.svg",
    label: "Education",
    description:
      "My academic background combines management research, innovation studies, and qualitative methods, with international research experience spanning Germany, Denmark, Portugal, the UK, and the USA.",
  },
  {
    href: "/community-roles",
    icon: "/icons/community-roles.svg",
    label: "Community roles",
    description:
      "I contribute to academic and professional communities through reviewing, representative work, research communities, and open infrastructure for scholarly exchange.",
  },
  {
    href: "/industry-work",
    icon: "/icons/industry-work.svg",
    label: "Industry work",
    description:
      "For about ten years, I worked in the industry as innovation manager, scrum master, and technical consultant.",
  },
];

const topics = [
  "artificial intelligence",
  "strategy",
  "innovation management",
  "knowledge processes",
  "corporate-startup collaboration",
  "qualitative methods",
];

const publications = [
  "Renzl, B., & Möllmann, J. (2025). Ambidexterity. In B. Grossmann-Hensel, P. Jarzabkowski, R. Kratochvil, D. Seidl, P. Spee, & R. Whittington (Eds.), Elgar Encyclopedia of Strategy as Practice (pp. 121-124). Edward Elgar Publishing.",
  "Möllmann, J. (2023). More than a handshake - knowledge transfer in structured corporate-startup collaboration programs. Journal of Knowledge Management, 27(10), 2604-2624.",
];
---

<BaseLayout {metadata}>
  <section class="mx-auto max-w-5xl px-5 py-12 sm:px-8 md:py-16">
    <div class="grid gap-12 lg:grid-cols-[1fr_0.72fr] lg:items-start">
      <div>
        <p
          class="font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground"
        >
          postdoctoral researcher
        </p>
        <h1
          class="mt-8 max-w-4xl text-5xl font-normal leading-[0.95] tracking-normal text-foreground sm:text-7xl md:text-8xl"
        >
          Juliane<br />Möllmann
        </h1>
        <p
          class="mt-5 font-mono text-sm uppercase tracking-[0.18em] text-muted-foreground"
        >
          PhD, Management
        </p>
      </div>

      <aside class="border-t border-border pt-5 lg:mt-3">
        <dl class="space-y-5 text-sm leading-6">
          <div>
            <dt
              class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground"
            >
              current
            </dt>
            <dd class="mt-1 text-foreground">
              Department of Industrial Engineering and Management, Aalto
              University
            </dd>
          </div>
          <div>
            <dt
              class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground"
            >
              affiliated
            </dt>
            <dd class="mt-1 text-foreground">
              Department of Business Development and Technology, Aarhus BSS
            </dd>
          </div>
        </dl>
        <div
          class="mt-7 flex flex-wrap gap-x-3 gap-y-2 font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground"
        >
          {
            topics.map((topic) => (
              <span class="border border-border px-2 py-1">{topic}</span>
            ))
          }
        </div>
      </aside>
    </div>
  </section>

  <section class="border-t border-border">
    <div class="mx-auto max-w-5xl px-5 py-10 sm:px-8">
      <div class="grid divide-y divide-border">
        {
          navItems.map((item) => (
            <a
              href={sitePath(item.href)}
              class="group grid gap-3 py-5 transition-colors hover:text-primary lg:grid-cols-[1fr_1.6fr] lg:items-baseline"
            >
              <span class="flex items-center gap-3 text-2xl leading-none text-foreground group-hover:text-primary">
                <img
                  src={sitePath(item.icon)}
                  alt=""
                  aria-hidden="true"
                  class="h-6 w-6 shrink-0"
                  loading="lazy"
                />
                {item.label}
              </span>
              <span class="text-sm leading-6 text-muted-foreground">
                {item.description}
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-border">
    <div
      class="mx-auto grid max-w-5xl gap-8 px-5 py-12 sm:px-8 lg:grid-cols-[0.55fr_1fr]"
    >
      <p
        class="font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground"
      >
        publications
      </p>
      <div class="divide-y divide-border">
        {
          publications.map((publication) => (
            <p class="py-6 text-sm leading-7 text-foreground first:pt-0">
              {publication}
            </p>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-border">
    <div
      class="mx-auto grid max-w-5xl gap-8 px-5 py-12 sm:px-8 lg:grid-cols-[0.55fr_1fr]"
    >
      <p
        class="font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground"
      >
        contact
      </p>
      <form
        action="mailto:juliane.moellmann@aalto.fi"
        method="post"
        enctype="text/plain"
        class="grid gap-5"
      >
      <div class="grid gap-2">
        <label
          for="contact-name"
          class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground"
        >
          name
        </label>
        <input
          id="contact-name"
          name="name"
          type="text"
          autocomplete="name"
          required
          class="w-full border border-border bg-background px-3 py-3 text-sm text-foreground outline-none transition-colors placeholder:text-muted-foreground focus:border-foreground"
          placeholder="Your name"
        />
      </div>

      <div class="grid gap-2">
        <label
          for="contact-email"
          class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground"
        >
          email
        </label>
        <input
          id="contact-email"
          name="email"
          type="email"
          autocomplete="email"
          required
          class="w-full border border-border bg-background px-3 py-3 text-sm text-foreground outline-none transition-colors placeholder:text-muted-foreground focus:border-foreground"
          placeholder="your@email.com"
        />
      </div>

      <div class="grid gap-2">
        <label
          for="contact-message"
          class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground"
        >
          message
        </label>
        <textarea
          id="contact-message"
          name="message"
          rows="5"
          required
          class="w-full resize-none border border-border bg-background px-3 py-3 text-sm text-foreground outline-none transition-colors placeholder:text-muted-foreground focus:border-foreground"
          placeholder="Research collaboration, teaching, or professional exchange"
        ></textarea>
      </div>

      <div class="flex flex-wrap items-center gap-4">
        <button
          type="submit"
          class="border border-foreground px-4 py-3 font-mono text-xs uppercase tracking-[0.14em] text-foreground transition-colors hover:bg-foreground hover:text-background"
        >
          send message
        </button>
      </div>
      </form>
    </div>
  </section>
</BaseLayout>
