---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Features from "@/components/widgets/Features.astro";
import Content from "@/components/widgets/Content.astro";
import Form from "@/components/ui/Form.astro";

const metadata = {
  title: "Contact - Juliane Möllmann",
  description: "Get in touch with Juliane Möllmann for research collaboration, teaching inquiries, or professional opportunities.",
};

const visionText = ["Get in touch to discuss research collaboration, teaching opportunities, or professional inquiries."];
---

<BaseLayout {metadata}>
  <Content tagline="Contact" title="Contact" description={visionText} />
  <div
    class="reveal mx-auto max-w-xl bg-card border border-border rounded-3xl p-8 shadow-sm mb-12 md:mb-16"
  >
    <Form />
  </div>
  <Features
    tagline="Contact Information"
    title="Get in Touch"
    subtitle="Connect with me through various channels for academic and professional discussions."
    classes={{ container: "pt-0 md:pt-0" }}
    features={[
      {
        title: "Email",
        description: "juliane.moellmann@aalto.fi",
        icon: "lucide:mail",
        iconClass: "bg-yellow-500/10 text-yellow-400",
      },
      {
        title: "LinkedIn",
        description: "Connect professionally",
        icon: "lucide:linkedin",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Google Scholar",
        description: "View publications",
        icon: "lucide:book-open",
        iconClass: "bg-green-500/10 text-green-400",
      },
      {
        title: "ResearchGate",
        description: "Research profile",
        icon: "lucide:users",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "ORCID",
        description: "Academic identifier",
        icon: "lucide:id-card",
        iconClass: "bg-red-500/10 text-red-400",
      },
      {
        title: "Web of Science",
        description: "Research metrics",
        icon: "lucide:bar-chart",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
    ]}
  />
</BaseLayout>
