---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { sitePath } from "@/utils/paths";

const articles = (await getCollection("articles"))
  .filter((article) => !article.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const metadata = {
  title: "Insights - Juliane Möllmann",
  description:
    "Insights, research notes, reflections, and essays by Juliane Möllmann.",
};

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-GB", {
    month: "long",
    year: "numeric",
  });
---

<BaseLayout {metadata}>
  <section class="mx-auto max-w-5xl px-5 py-12 sm:px-8 md:py-16">
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground">
        Writing
      </p>
      <h1
        class="mt-6 max-w-4xl text-5xl font-normal leading-none tracking-normal text-foreground sm:text-7xl"
      >
        Insights
      </h1>
      <p class="mt-8 max-w-3xl text-2xl leading-tight text-foreground">
        Longer notes, essays, and reflections on research, teaching,
        technology, strategy, and organizational life.
      </p>
    </div>
  </section>

  <section class="border-t border-border">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <div class="divide-y divide-border">
        {
          articles.map((article) => (
            <article class="grid gap-5 py-8 md:grid-cols-[10rem_1fr]">
              <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">
                {formatDate(article.data.pubDate)}
              </p>
              <div>
                <a href={sitePath(`/insights/${article.id}`)} class="group">
                  <h2 class="max-w-3xl text-3xl font-normal leading-tight text-foreground transition-colors group-hover:text-muted-foreground sm:text-4xl">
                    {article.data.title}
                  </h2>
                </a>
                <p class="mt-4 max-w-3xl text-base leading-7 text-muted-foreground">
                  {article.data.description}
                </p>
                {article.data.tags && article.data.tags.length > 0 && (
                  <div class="mt-5 flex flex-wrap gap-x-3 gap-y-2 font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">
                    {article.data.tags.map((tag) => (
                      <span class="border border-border px-2 py-1">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
